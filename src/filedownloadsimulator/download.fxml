<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="20" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/24.0.1" fx:controller="filedownloadsimulator.DownloadController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <!-- Title -->
    <Label style="-fx-font-size:18px; -fx-font-weight:bold;" text="File Download Simulator" />

    <!-- File 1 -->
    <VBox spacing="5">
        <Label text="file1.mp4" />
        <HBox spacing="10">
            <ProgressBar fx:id="progressBar1" prefWidth="300" progress="0" />
            <Label fx:id="status1" text="Waiting" />
        </HBox>
    </VBox>

    <!-- File 2 -->
    <VBox spacing="5">
        <Label text="file2.zip" />
        <HBox spacing="10">
            <ProgressBar fx:id="progressBar2" prefWidth="300" progress="0" />
            <Label fx:id="status2" text="Waiting" />
        </HBox>
    </VBox>

    <!-- File 3 -->
    <VBox spacing="5">
        <Label text="file3.pdf" />
        <HBox spacing="10">
            <ProgressBar fx:id="progressBar3" prefWidth="300" progress="0" />
            <Label fx:id="status3" text="Waiting" />
        </HBox>
    </VBox>

    <!-- Start Button -->
    <Button fx:id="startButton" onAction="#startDownloads" prefHeight="26.0" prefWidth="162.0" text="Start Downloads" />

</VBox>
